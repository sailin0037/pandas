   "id": "imports",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "dataset",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Dataset\n",
    "data = {\n",
    "    'Price': [50, 60, 70, 80, 90, 100],\n",
    "    'Bottles Sold': [120, 100, 85, 70, 50, 30]\n",
    "}\n",
    "df = pd.DataFrame(data)\n",
    "df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "revenue",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate Revenue\n",
    "df['Revenue'] = df['Price'] * df['Bottles Sold']\n",
    "df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "optimal-price",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Highest Revenue & Optimal Price\n",
    "max_rev = df['Revenue'].max()\n",
    "opt_price = df.loc[df['Revenue'].idxmax(), 'Price']\n",
    "max_rev, opt_price"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "chart",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Bar Chart: Price vs Revenue\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.bar(df['Price'], df['Revenue'], color='steelblue', edgecolor='black')\n",
    "plt.xlabel('Price (₹)')\n",
    "plt.ylabel('Revenue (₹)')\n",
    "plt.title('Price vs Revenue Analysis')\n",
    "plt.xticks(df['Price'])\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
